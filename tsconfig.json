{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["vitest/globals"],
    "allowImportingTsExtensions": true, // lets `import ... from "./x.ts"` work
    "noEmit": true // required
  },
  "include": ["**/*.ts"]
}
